<div class="flex flex-col items-center justify-center min-h-full p-6 bg-linen">
    <div class="text-center max-w-sm w-full">
        <div class="animate-fade-slide-up">
            <h1 class="font-heading text-5xl font-bold text-primary mb-1">Soc Ops</h1>
            <p class="text-muted text-base tracking-wide mb-8">Social Bingo</p>
        </div>

        <div class="bg-surface rounded-2xl border border-calm p-6 mb-6 shadow-md animate-fade-slide-up delay-1">
            <h2 class="font-heading font-bold text-primary mb-4">How to play</h2>
            <ul class="text-left text-muted text-sm font-light space-y-2">
                <li>— Find people who match the questions</li>
                <li>— Tap a square when you find a match</li>
                <li>— Get 5 in a row to win</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-sage text-white font-semibold tracking-wide py-4 px-8 rounded-2xl text-base transition-colors animate-fade-slide-up delay-2">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
