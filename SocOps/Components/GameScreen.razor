@using SocOps.Models

<div class="flex flex-col min-h-full bg-linen">
    <header class="flex items-center justify-between px-4 py-3 bg-surface border-b border-calm">
        <button
            @onclick="OnReset"
            class="text-muted text-sm tracking-wide px-3 py-1.5 rounded">
            ← Back
        </button>
        <h1 class="text-xs font-bold tracking-widest uppercase text-primary">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <p class="text-center text-muted text-xs tracking-wide py-3 px-4">
        Tap a square when you find someone who matches it.
    </p>

    @if (HasBingo)
    {
        <div class="bg-winning-calm text-winning text-center py-2 tracking-widest text-xs font-bold uppercase">
            ✦ Bingo — line complete
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
