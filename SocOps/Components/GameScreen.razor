@using SocOps.Models

<div class="flex flex-col min-h-full bg-linen">
    <header class="flex items-center justify-between px-4 py-3 bg-surface border-b border-calm shadow-sm">
        <button
            @onclick="OnReset"
            class="text-muted text-sm tracking-wide px-3 py-1.5 rounded">
            ← Back
        </button>
        <h1 class="font-heading font-bold text-primary">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <p class="text-center text-muted text-sm font-light py-3 px-4">
        Tap a square when you find someone who matches it.
    </p>

    @if (HasBingo)
    {
        <div class="bg-marked-calm text-marked text-center py-2 tracking-wide text-sm font-semibold">
            ✦ Bingo — you completed a line!
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
