<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-surface rounded-xl p-8 max-w-xs w-full text-center animate-fade-in border border-calm">
        <div class="text-5xl mb-4">✦</div>
        <h2 class="text-2xl font-bold tracking-widest uppercase text-primary mb-2">Bingo</h2>
        <p class="text-muted text-sm tracking-wide mb-6">You completed a line.</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-sage text-white font-bold tracking-widest uppercase py-3 px-6 rounded-xl text-sm transition-colors">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
