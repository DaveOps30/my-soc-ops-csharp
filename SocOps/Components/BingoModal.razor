<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-surface rounded-2xl p-8 max-w-xs w-full text-center shadow-md animate-fade-in">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="font-heading text-3xl font-bold text-primary mb-2">Bingo!</h2>
        <p class="text-muted text-sm font-light tracking-wide mb-6">You completed a line.</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-sage text-white font-semibold tracking-wide py-3 px-6 rounded-2xl transition-colors">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
